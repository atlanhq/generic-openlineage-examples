# Atlan OpenLineage endpoint
# Replace <your-tenant> with your Atlan tenant domain (e.g. mycompany.atlan.com)
# Replace <connector-name> with your configured connector name (e.g. generic-openlineage)
OL_ENDPOINT=https://<your-tenant>.atlan.com/events/openlineage/<connector-name>/api/v1/lineage

# Atlan API key (generate from Settings > API Keys)
API_KEY=<your-api-key>
